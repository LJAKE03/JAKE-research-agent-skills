{
  "schema_version": 2,
  "configuration_version": "1.5.0",
  "model_mapping_version": "sol-terra-luna-unified-v5",
  "provider": "ChatGPT Windows desktop app and Codex",
  "primary_surface": "project-scoped .codex agents",
  "verified_with": {
    "command": "codex debug models",
    "codex_cli_version": "0.144.1"
  },
  "workflow": {
    "default": "unified",
    "max_initial_blocking_questions": 2,
    "continue_low_risk_work_packages": true,
    "sol_semantic_acceptance_when": ["publication_or_submission", "key_parameter_or_core_method", "safety_or_high_cost_decision", "scientific_final_acceptance"]
  },
  "runtime_preflight": {
    "command": "codex debug models",
    "strategic_unavailable_status": "blocked_model_catalog",
    "support_or_economy_unavailable_status": "degraded_sol_only"
  },
  "runtime_dispatch": {
    "support_agent_type": "research_support",
    "economy_agent_type": "research_output",
    "fork_turns": "none",
    "preferred_call_shape": "agent_type",
    "compatible_call_shape": "explicit_model",
    "isolated_call_shape": "codex_exec",
    "require_runtime_evidence": true,
    "require_spawn_evidence": true,
    "self_report_is_evidence": false,
    "failure_status": "degraded_sol_only"
  },
  "tiers": {
    "strategic": {
      "model": "gpt-5.6-sol",
      "reasoning_effort": "xhigh",
      "sandbox_mode": "workspace-write",
      "purpose": "requirements, orchestration, method selection, evidence synthesis, key scientific judgement, and compact final acceptance"
    },
    "support": {
      "model": "gpt-5.6-terra",
      "reasoning_effort": "medium",
      "sandbox_mode": "read-only",
      "purpose": "bounded literature search, web verification, file scanning, extraction, evidence tables, and provenance checks"
    },
    "economy": {
      "model": "gpt-5.6-luna",
      "reasoning_effort": "low",
      "sandbox_mode": "read-only",
      "purpose": "prose drafting, language, and formatting from a complete locked research writing package"
    }
  },
  "fallback": {
    "same_model_reasoning_tiers": false,
    "status": "degraded_sol_only",
    "when_support_or_economy_is_unavailable": "return the bounded task to strategic Sol; do not substitute an unverified model"
  },
  "delegation": {
    "max_threads": 2,
    "max_depth": 1,
    "subagents_may_delegate": false,
    "main_agent_reads_every_result": true,
    "main_agent_final_review": true
  },
  "quality_gates": {
    "L0": "deterministic tool checks",
    "L1": "read-only provenance and evidence-completeness checks",
    "L2": "strategic scientific judgement and final acceptance"
  }
}
