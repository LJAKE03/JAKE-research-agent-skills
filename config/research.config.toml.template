# Copy this file to $CODEX_HOME/research.config.toml to use it with:
#   codex --profile research
# This repository never overwrites the user's existing Codex configuration.

# Sol, Terra, and Luna were verified locally with codex debug models.
# This optional CLI compatibility profile deliberately keeps its main thread on
# Sol; project-level app agents route support and economy work to Terra and Luna.
model = "gpt-5.6-sol"

# The profile pins the strategic root to xhigh. Project-scoped custom Agent
# roles lock Terra to medium and Luna to low without per-task user selection.
model_reasoning_effort = "xhigh"
